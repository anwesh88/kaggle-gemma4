# Finsight OS — backend environment variables
# Copy this to .env and fill in values you need.

# ── Core ─────────────────────────────────────────────────────────────────────
DEMO_MODE=true                        # seeds the high-risk demo session on first run
FRONTEND_URL=http://localhost:3000    # for CORS allowlist

# ── Gemma / Ollama ──────────────────────────────────────────────────────────
# E2B is the smaller, faster variant — recommended for CPU. Switch to gemma4:e4b
# only if you have a GPU and want the larger model's slightly better outputs.
OLLAMA_MODEL=gemma4:e2b
OLLAMA_HOST=http://localhost:11434
OLLAMA_TIMEOUT_S=90                    # UI shows Gemma unavailable past this

# CPU defaults (i7-1255U / 16GB). Override on GPU instance — see docs/gpu-setup.md
OLLAMA_NUM_PREDICT=200
OLLAMA_NUM_CTX=768
OLLAMA_NUM_THREAD=8
OLLAMA_NUM_GPU=0                       # 99 to offload all layers to GPU
OLLAMA_TEMPERATURE=0.1
OLLAMA_TOP_P=0.9
OLLAMA_REPEAT_PENALTY=1.05
OLLAMA_KEEP_ALIVE=5m                   # 30m or -1 on GPU instances for hot inference

# Chart Analyzer vision model. Both gemma4:e2b and gemma4:e4b are
# natively multimodal — leave this blank (or omit) to reuse OLLAMA_MODEL
# above. Set explicitly only if you want a different model for vision
# (e.g. gemma4:e4b for higher fidelity, llava:7b on systems without
# Gemma 4, etc).
# OLLAMA_VISION_MODEL=gemma4:e4b
OLLAMA_VISION_TIMEOUT_S=120
# Clear charts use the deterministic fast path, so skip this on ordinary CPU
# laptops. Turn it on only if you expect many ambiguous charts to fall back to
# Gemma vision and want to pay the cold-start cost during boot instead.
OLLAMA_PREWARM_VISION=false

# ── Live Kite Connect (optional, Free tier supported) ──────────────────────
# Register a free Kite Connect app at https://kite.trade/connect/
# Register the redirect URL on your Kite app EXACTLY as KITE_REDIRECT_URL below.
# Canonical local setup is localhost, not 127.0.0.1.
# Leave these blank to keep Live Kite mode disabled — Demo + Paper still work.
KITE_API_KEY=
KITE_API_SECRET=
KITE_REDIRECT_URL=http://localhost:8000/kite/callback
# After OAuth, the access_token is Fernet-encrypted at
# data/kite_access_token.encrypted with the key at data/kite_secret.key.
# Token, key, and profile files are git-ignored. Restarting the backend auto-restores the
# session as long as the saved token hasn't hit the daily 6 AM IST expiry.
# Manual login alternative (Docker / headless): cd backend && python scripts/kite_login.py

# ── Paper trading ──────────────────────────────────────────────────────────
PAPER_CAPITAL=100000                   # ₹1 lakh notional for paper accounts
