# Finsight OS - backend Dockerfile for local/full Docker runs only.
#
# Builds a single image that contains:
#   - Python 3.11 + the FastAPI backend
#   - Ollama binary + gemma4:e2b weights pre-pulled into the layer
#
# Designed for `docker compose up` from the repo root, but also runnable
# standalone:
#   docker build -f ./backend/Dockerfile.local -t finsight-backend ./backend
#   docker run -p 8000:8000 -p 11434:11434 -v ./backend/data:/app/data finsight-backend
#
# Do not rename this file to `Dockerfile` in `backend/` for Railway deploys.
# Railway should use Railpack + requirements.txt, not this local Ollama image.

FROM python:3.11-slim

# OS deps + Ollama binary (single-step layer for caching).
# Ollama's installer currently requires zstd to extract the release archive.
RUN apt-get update \
 && apt-get install -y --no-install-recommends curl ca-certificates zstd \
 && curl -fsSL https://ollama.com/install.sh | sh \
 && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install Python deps first (layer caches across code changes)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Pre-pull Gemma 4 E2B into the image so first-run is fast.
# This adds several GB to the image but saves a cold model pull on each fresh container.
RUN ollama serve & \
    sleep 5 && \
    ollama pull gemma4:e2b && \
    pkill ollama || true

# Copy the application
COPY . .

# Both the FastAPI port and the Ollama port.
EXPOSE 8000 11434

# Default env - overridable via docker compose or `docker run -e`.
ENV DEMO_MODE=true \
    OLLAMA_HOST=http://localhost:11434 \
    OLLAMA_MODEL=gemma4:e2b \
    OLLAMA_NUM_GPU=0 \
    PYTHONUNBUFFERED=1

# Start Ollama in background, then the FastAPI server in foreground.
COPY <<'EOF' /entrypoint.sh
#!/bin/sh
set -e
ollama serve > /tmp/ollama.log 2>&1 &
sleep 3
exec python main.py
EOF
RUN chmod +x /entrypoint.sh

CMD ["/entrypoint.sh"]
